{
  "version": 3,
  "configurePresets": [
    {
      "name": "vcpkg",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build/vcpkg_installed",
        "BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "macos-vcpkg",
      "inherits": "vcpkg",
      "binaryDir": "${sourceDir}/build-macos",
      "cacheVariables": {
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-macos/vcpkg_installed",
        "VCPKG_TARGET_TRIPLET": "arm64-osx",
        "Vulkan_INCLUDE_DIR": "$env{VULKAN_SDK}/macOS/include",
        "Vulkan_LIBRARY": "$env{VULKAN_SDK}/macOS/lib/libvulkan.dylib"
      }
    },
    {
      "name": "ios-vcpkg",
      "inherits": "vcpkg",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build-ios-xcode",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-ios-xcode/vcpkg_installed",
        "VCPKG_TARGET_TRIPLET": "arm64-ios",
        "Vulkan_INCLUDE_DIR": "$env{VULKAN_SDK}/macOS/include",
        "Vulkan_LIBRARY": "$env{VULKAN_SDK}/iOS/lib/vulkan.framework/vulkan"
      }
    }
  ]
}
